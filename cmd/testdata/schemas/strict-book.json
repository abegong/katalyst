{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "strict-book",
  "type": "object",
  "required": ["title", "year", "isbn"],
  "properties": {
    "title": { "type": "string" },
    "year":  { "type": "integer" },
    "isbn":  { "type": "string", "pattern": "^[0-9-]+$" }
  }
}
