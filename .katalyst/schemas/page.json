{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "page",
  "type": "object",
  "required": ["title"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "weight": { "type": "integer" },
    "draft": { "type": "boolean" },
    "bookCollapseSection": { "type": "boolean" },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
